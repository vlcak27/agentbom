{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentbom.dev/schemas/output-schema.json",
  "title": "AgentBOM Output",
  "type": "object",
  "required": [
    "schema_version",
    "providers",
    "models",
    "frameworks",
    "capabilities",
    "dependencies",
    "reachable_capabilities",
    "capability_graph",
    "policy_findings",
    "repository_risk",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "providers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_finding"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model_finding"
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_finding"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_finding"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency_finding"
      }
    },
    "reachable_capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reachable_capability"
      }
    },
    "capability_graph": {
      "$ref": "#/$defs/capability_graph"
    },
    "policy_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policy_finding"
      }
    },
    "repository_risk": {
      "$ref": "#/$defs/repository_risk"
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    }
  },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "named_finding": {
      "type": "object",
      "required": [
        "name",
        "path",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "model_finding": {
      "type": "object",
      "required": [
        "type",
        "name",
        "source_file",
        "confidence",
        "evidence"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "dependency_finding": {
      "type": "object",
      "required": [
        "name",
        "category",
        "path",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "ai_framework",
            "mcp",
            "sandbox_runtime"
          ]
        },
        "path": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "reachable_capability": {
      "type": "object",
      "required": [
        "capability",
        "reachable_from",
        "source_file",
        "risk",
        "confidence"
      ],
      "properties": {
        "capability": {
          "type": "string"
        },
        "reachable_from": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "confidence_score": {
          "type": "integer"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "prompt_input",
              "tool_invocation",
              "shell_execution",
              "network_execution"
            ]
          }
        }
      }
    },
    "repository_risk": {
      "type": "object",
      "required": [
        "score",
        "severity",
        "rationale"
      ],
      "properties": {
        "score": {
          "type": "integer"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "required": [
        "severity",
        "reason"
      ],
      "properties": {
        "severity": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "policy_finding": {
      "type": "object",
      "required": [
        "severity",
        "message",
        "source_file"
      ],
      "properties": {
        "severity": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "policy_id": {
          "type": "string"
        }
      }
    },
    "capability_graph": {
      "type": "object",
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_edge"
          }
        }
      }
    },
    "graph_node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "model",
            "framework",
            "capability",
            "provider"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    "graph_edge": {
      "type": "object",
      "required": [
        "source",
        "target",
        "type"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "uses",
            "enables",
            "reaches"
          ]
        }
      }
    }
  }
}
